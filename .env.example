# Backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=demo

# Academic-Nexus Docker host ports. Container-internal ports stay unchanged.
MAIN_HOST_PORT=8088
FRONTEND_HOST_PORT=5174
MYSQL_HOST_PORT=13306
REDIS_HOST_PORT=16379
NACOS_HOST_PORT=18848
NACOS_GRPC_HOST_PORT=19848
AI_SERVICE_HOST_PORT=18090

# Docker Maven build mirror. Keep Central by default; scripts can switch this.
MAVEN_MIRROR_URL=https://repo.maven.apache.org/maven2

# MySQL
DB_URL=jdbc:mysql://localhost:3306/tianshiwebside?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change_me

# Redis, optional. If Redis is unavailable, the application falls back to database mode.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Course grab remote switch
COURSE_GRAB_REMOTE_ENABLED=false

# AI service
AI_SERVICE_PORT=8090
AI_SERVICE_URL=http://localhost:8090
AI_SERVICE_NAME=academic-ai-service
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_SQL_MODEL=qwen2.5-coder:7b

# Optional AI web search provider. Keep placeholders in source control.
SEARCH_ENABLED=false
SEARCH_PROVIDER=LOCAL_DEMO
SEARCH_ENDPOINT=
SEARCH_API_KEY=
SEARCH_TIMEOUT_MS=8000
SEARCH_RESULT_LIMIT=5
SEARCH_SAFE_MODE=true

# Spring Cloud / Nacos
NACOS_ADDR=127.0.0.1:8848
NACOS_DISCOVERY_ENABLED=false
NACOS_REGISTER_ENABLED=false
AI_SERVICE_DISCOVERY_ENABLED=false
